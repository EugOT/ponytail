#!/usr/bin/env bash
# ponytail-launch — resolve a ponytail Zig binary and exec it (passing stdin + args).
#
# Used by the Claude Code plugin (.claude-plugin/plugin.json) so the plugin can run
# the native Zig hooks without bundling per-platform blobs: it finds an already-
# installed binary, or a local build, or downloads+verifies the per-platform release
# archive on first use (cached under $PONYTAIL_CACHE), then execs the requested binary.
#
# Usage:  ponytail-launch <binary-name> [args...]      (stdin is forwarded)
#   e.g.  ponytail-launch ponytail-activate
#         ponytail-launch ponytail-hook
#
# Resolution order:
#   1. $CLAUDE_CONFIG_DIR/hooks/<name>        (standalone install dropped it here)
#   2. <plugin-root>/zig/zig-out/bin/<name>   (local clone / dev build)
#   3. $PONYTAIL_CACHE/<name>                 (previously downloaded)
#   4. download ponytail-<plat>.tar.gz from the latest Release → SHA-256 verify →
#      extract into $PONYTAIL_CACHE → use it
#
# Pure-Zig runtime: this launcher is host-automation shell, not application logic.
set -uo pipefail

REPO="EugOT/ponytail"
NAME="${1:-}"
[ -n "$NAME" ] || { echo "ponytail-launch: missing binary name" >&2; exit 2; }
shift || true

here="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" 2>/dev/null && pwd)" || here=""
CACHE="${PONYTAIL_CACHE:-${XDG_CACHE_HOME:-$HOME/.cache}/ponytail/bin}"

# exec the binary at $1 with all remaining launcher args ($@, already shifted past
# the binary name) if it exists and is executable; otherwise return so the next
# resolution step runs. stdin is inherited by exec, so hooks still read it.
try_exec() { local b="$1"; shift; [ -x "$b" ] && exec "$b" "$@"; }

# 1. standalone-installed hooks dir
CFG="${CLAUDE_CONFIG_DIR:-$HOME/.claude}"
try_exec "$CFG/hooks/$NAME" "$@"

# 2. local clone / dev build (launcher lives at bin/, zig/ is a sibling at repo root)
[ -n "$here" ] && try_exec "$here/../zig/zig-out/bin/$NAME" "$@"

# 3. previously downloaded
try_exec "$CACHE/$NAME" "$@"

# 4. download + verify + cache
detect_platform() {
  local os arch; os="$(uname -s)"; arch="$(uname -m)"
  case "$os" in Darwin) os=macos ;; Linux) os=linux ;; *) echo "ponytail-launch: unsupported OS $os (Windows uses the PowerShell shim)" >&2; exit 1 ;; esac
  case "$arch" in arm64|aarch64) arch=arm64 ;; x86_64|amd64) arch=x64 ;; *) echo "ponytail-launch: unsupported arch $arch" >&2; exit 1 ;; esac
  printf '%s-%s' "$os" "$arch"
}
sha256_of() {
  if command -v sha256sum >/dev/null 2>&1; then sha256sum "$1" | awk '{print $1}'
  elif command -v shasum >/dev/null 2>&1; then shasum -a 256 "$1" | awk '{print $1}'
  else echo "ponytail-launch: no sha256 tool" >&2; exit 1; fi
}

command -v curl >/dev/null 2>&1 || { echo "ponytail-launch: curl required to fetch binaries" >&2; exit 1; }
plat="$(detect_platform)"
archive="ponytail-$plat.tar.gz"
base="https://github.com/$REPO/releases/latest/download"
tmp="$(mktemp -d "${TMPDIR:-/tmp}/ponytail-launch.XXXXXX")"
trap 'rm -rf "$tmp"' EXIT

curl -fsSL "$base/$archive"        -o "$tmp/$archive"        || { echo "ponytail-launch: download failed ($archive)" >&2; exit 1; }
curl -fsSL "$base/$archive.sha256" -o "$tmp/$archive.sha256" || { echo "ponytail-launch: checksum download failed" >&2; exit 1; }
want="$(awk '{print $1}' "$tmp/$archive.sha256")"; got="$(sha256_of "$tmp/$archive")"
[ "$want" = "$got" ] || { echo "ponytail-launch: SHA-256 mismatch — refusing" >&2; exit 1; }

mkdir -p "$CACHE"
tar -C "$CACHE" -xzf "$tmp/$archive" || { echo "ponytail-launch: extract failed" >&2; exit 1; }
chmod +x "$CACHE"/ponytail-* 2>/dev/null || true
try_exec "$CACHE/$NAME" "$@"

echo "ponytail-launch: could not resolve '$NAME' (not in archive?)" >&2
exit 1
