{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "\"${PLUGIN_ROOT}/bin/ponytail-launch\" ponytail-activate",
        "timeoutSec": 30
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "\"${PLUGIN_ROOT}/bin/ponytail-launch\" ponytail-hook",
        "timeoutSec": 30
      }
    ]
  }
}
